{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022", "dom", "dom.iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@repo/types": ["shell/src/shared/types/index.ts"],
      "@repo/ui": ["shell/src/shared/ui/index.ts"],
      "@/*": ["./src/*"]
    }
  }
}
